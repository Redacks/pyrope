<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="700"
             x:Class="pyropeGUI.Views.ProjectMenu.ProjectMenu">
  <Grid Background="{DynamicResource DarkBlackBackground}" RowDefinitions="60,*" ColumnDefinitions="*,*,*,*,*">
    <Panel Background="{DynamicResource LightBlackBackground}" Grid.ColumnSpan="5">
      <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource LightWhiteText}" FontSize="24">Project</TextBlock>
    </Panel>
    <Button Foreground="{DynamicResource LightWhiteText}" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
      Hello There
    </Button>
    <Button Foreground="{DynamicResource LightWhiteText}" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
      Hello There
    </Button>
  </Grid>
</UserControl>
